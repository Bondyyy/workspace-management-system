                  <SubComponents>
                    <Component class="javax.swing.JLabel" name="lblRichText">
                      <Properties>
                        <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;body style=&apos;font-family: Segoe UI; padding: 20px; color: #301e23;&apos;&gt;&lt;h2 style=&apos;color: #eb5e8d; margin-top: 0;&apos;&gt;H&#x1ec7; th&#x1ed1;ng Qu&#x1ea3;n l&#xfd; Kh&#xf4;ng gian L&#xe0;m vi&#x1ec7;c v&#xe0; H&#x1ecd;c t&#x1ead;p (Spring System)&lt;/h2&gt;&lt;p style=&apos;font-size: 14px; line-height: 1.5;&apos;&gt;&lt;b&gt;Spring System&lt;/b&gt; l&#xe0; gi&#x1ea3;i ph&#xe1;p ph&#x1ea7;n m&#x1ec1;m to&#xe0;n di&#x1ec7;n gi&#xfa;p s&#x1ed1; h&#xf3;a v&#xe0; t&#x1ef1; &#x111;&#x1ed9;ng h&#xf3;a quy tr&#xec;nh v&#x1ead;n h&#xe0;nh c&#xe1;c m&#xf4; h&#xec;nh Kh&#xf4;ng gian l&#xe0;m vi&#x1ec7;c chung. H&#x1ec7; th&#x1ed1;ng gi&#x1ea3;i quy&#x1ebf;t tri&#x1ec7;t &#x111;&#x1ec3; c&#xe1;c h&#x1ea1;n ch&#x1ebf; c&#x1ee7;a qu&#x1ea3;n l&#xfd; th&#x1ee7; c&#xf4;ng, mang l&#x1ea1;i tr&#x1ea3;i nghi&#x1ec7;m li&#x1ec1;n m&#x1ea1;ch cho kh&#xe1;ch h&#xe0;ng t&#x1eeb; l&#xfa;c &#x111;&#x1eb7;t ch&#x1ed7; &#x111;&#x1ebf;n khi thanh to&#xe1;n.&lt;/p&gt;&lt;h3 style=&apos;color: #eb5e8d;&apos;&gt;C&#xe1;c t&#xed;nh n&#x103;ng n&#x1ed5;i b&#x1ead;t:&lt;/h3&gt;&lt;ul style=&apos;font-size: 14px; line-height: 1.5;&apos;&gt;&lt;li&gt;&lt;b&gt;T&#x1ed1;i &#x1b0;u &#x110;&#x1eb7;t ch&#x1ed7; &amp; Kh&#xf4;ng gian:&lt;/b&gt; Tr&#x1ef1;c quan h&#xf3;a s&#x1a1; &#x111;&#x1ed3; ch&#x1ed7; ng&#x1ed3;i, &#x111;&#x1eb7;t ch&#x1ed7; tr&#x1ef1;c tuy&#x1ebf;n, c&#x1ead;p nh&#x1ead;t tr&#x1ea1;ng th&#xe1;i theo th&#x1edd;i gian th&#x1ef1;c.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Tr&#x1ea3;i nghi&#x1ec7;m Ti&#x1ec7;n &#xed;ch Li&#x1ec1;n m&#x1ea1;ch:&lt;/b&gt; G&#x1ecd;i &#x111;&#x1ed3; u&#x1ed1;ng (F&amp;B), thu&#xea; thi&#x1ebf;t b&#x1ecb; v&#xe0; gia h&#x1ea1;n th&#x1edd;i gian s&#x1eed; d&#x1ee5;ng ngay t&#x1ea1;i b&#xe0;n.&lt;/li&gt;&lt;li&gt;&lt;b&gt;Qu&#x1ea3;n l&#xfd; T&#xe0;i ch&#xed;nh &amp; H&#x1ed9;i vi&#xea;n:&lt;/b&gt; Thanh to&#xe1;n t&#x1ead;p trung m&#x1ed9;t l&#x1ea7;n khi ra v&#x1ec1;, qu&#x1ea3;n l&#xfd; h&#x1ea1;ng th&#xe0;nh vi&#xea;n, t&#xed;ch &#x111;i&#x1ec3;m v&#xe0; t&#x1ef1; &#x111;&#x1ed9;ng &#xe1;p d&#x1ee5;ng m&#xe3; gi&#x1ea3;m gi&#xe1;.&lt;/li&gt;&lt;li&gt;&lt;b&gt;V&#x1ead;n h&#xe0;nh Chu&#x1ed7;i &amp; T&#x1ef1; &#x111;&#x1ed9;ng h&#xf3;a:&lt;/b&gt; B&#xe1;o c&#xe1;o doanh thu chi ti&#x1ebf;t, l&#x1b0;u v&#x1ebf;t giao d&#x1ecb;ch v&#xe0; s&#x1eb5;n s&#xe0;ng t&#xed;ch h&#x1ee3;p ki&#x1ec3;m so&#xe1;t c&#x1eed;a b&#x1eb1;ng m&#xe3; QR.&lt;/li&gt;&lt;/ul&gt;&lt;p style=&apos;font-size: 13px; font-style: italic; color: #888888; margin-top: 15px;&apos;&gt;&#x110;&#x1ec1; t&#xe0;i &#x111;&#x1b0;&#x1ee3;c th&#x1ef1;c hi&#x1ec7;n b&#x1edf;i nh&#xf3;m sinh vi&#xea;n l&#x1edb;p HTTT2024.1 - Tr&#x1b0;&#x1edd;ng &#x110;&#x1ea1;i h&#x1ecd;c C&#xf4;ng ngh&#x1ec7; Th&#xf4;ng tin (UIT).&lt;br&gt;C&#xf4;ng c&#x1ee5; ph&#xe1;t tri&#x1ec3;n: Java Swing, Oracle Database, DataGrip, Netbeans, Lucidchart.&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;"/>
                        <Property name="verticalAlignment" type="int" value="1"/>
                      </Properties>
                      <Constraints>
                        <Constraint layoutClass="org.netbeans.modules.form.compat2.layouts.DesignAbsoluteLayout" value="org.netbeans.modules.form.compat2.layouts.DesignAbsoluteLayout$AbsoluteConstraintsDescription">
                          <AbsoluteConstraints x="0" y="0" width="800" height="420"/>
                        </Constraint>
                      </Constraints>
                    </Component>
                  </SubComponents>
                </Container>
              </SubComponents>
