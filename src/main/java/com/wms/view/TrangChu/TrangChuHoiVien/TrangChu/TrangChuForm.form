            <Component class="javax.swing.JLabel" name="lblPromoBanner">
              <Properties>
                <Property name="text" type="java.lang.String" value="&lt;html&gt;&lt;div style=&apos;padding:15px; text-align:center;&apos;&gt;&lt;h2 style=&apos;color:#EB5E8D; margin-bottom:5px;&apos;&gt;Ph&#xf2;ng h&#x1ecd;p SPRING 01&lt;/h2&gt;&lt;h4 style=&apos;color:#888; margin-top:0;&apos;&gt;S&#x1ee9;c ch&#x1ee9;a: 10 Ng&#x1b0;&#x1edd;i&lt;/h4&gt;&lt;p style=&apos;font-size:13px; color:#444; line-height:1.5;&apos;&gt;Kh&#xf4;ng gian ri&#xea;ng t&#x1b0;, y&#xea;n t&#x129;nh. Trang b&#x1ecb; &#x111;&#x1ea7;y &#x111;&#x1ee7; m&#xe1;y chi&#x1ebf;u, b&#x1ea3;ng tr&#x1eaf;ng, &#xe2;m thanh hi&#x1ec7;n &#x111;&#x1ea1;i.&lt;br&gt;&lt;br&gt;&lt;b&gt;Gi&#x1ea3;m 10%&lt;/b&gt; cho H&#x1ed9;i vi&#xea;n VIP.&lt;/p&gt;&lt;/div&gt;&lt;/html&gt;"/>
                <Property name="verticalAlignment" type="int" value="1"/>
                <Property name="border" type="javax.swing.border.Border" editor="org.netbeans.modules.form.editors2.BorderEditor">
                  <Border info="org.netbeans.modules.form.compat2.border.LineBorderInfo">
                    <LineBorder/>
                  </Border>
                </Property>
              </Properties>
              <Constraints>
